# ── SmartCampusConnect X — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is already in .gitignore.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# Public URL of this deployment (used for QR codes, OAuth callbacks, email links)
APP_URL="http://localhost:3000"

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the JSON flat-file database (default: ./db.json)
# In production, point this to a persistent volume path.
DB_PATH="./db.json"

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign session tokens (min 32 chars, keep private)
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# Session TTL in hours (default: 24)
SESSION_TTL_HOURS=24

# ── File Uploads ──────────────────────────────────────────────────────────────
# Directory where uploaded files (avatars, documents) are stored
UPLOAD_DIR="./uploads"

# Max upload size in MB (default: 10)
MAX_UPLOAD_MB=10

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# Required for AI Engine features (study assistant, risk scoring, timetable AI)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL="gemini-2.5-flash"

# ── Email / Notifications (optional) ─────────────────────────────────────────
# SMTP settings for sending password reset and notification emails
# Leave blank to disable email sending (in-app notifications only)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@smartcampus.app"

# ── Push Notifications (optional) ────────────────────────────────────────────
# VAPID keys for Web Push API (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@smartcampus.app"
