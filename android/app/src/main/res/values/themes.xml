<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SmartCampusConnectX" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#4f46e5</item>
        <item name="colorPrimaryVariant">#3730a3</item>
        <item name="colorOnPrimary">#ffffff</item>
        <item name="colorSecondary">#a855f7</item>
        <item name="colorSecondaryVariant">#7e22ce</item>
        <item name="colorOnSecondary">#ffffff</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.SmartCampusConnectX.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash screen theme — shown while LoginActivity loads -->
    <style name="Theme.SmartCampusConnectX.Splash" parent="Theme.SmartCampusConnectX.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
