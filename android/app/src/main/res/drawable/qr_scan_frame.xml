<?xml version="1.0" encoding="utf-8"?>
<!-- QR scan corner brackets overlay -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top-left corner -->
    <item android:top="0dp" android:left="0dp" android:bottom="185dp" android:right="185dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#4f46e5"/>
            <corners android:topLeftRadius="4dp"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- Top-right corner -->
    <item android:top="0dp" android:left="185dp" android:bottom="185dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#4f46e5"/>
            <corners android:topRightRadius="4dp"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- Bottom-left corner -->
    <item android:top="185dp" android:left="0dp" android:bottom="0dp" android:right="185dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#4f46e5"/>
            <corners android:bottomLeftRadius="4dp"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- Bottom-right corner -->
    <item android:top="185dp" android:left="185dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#4f46e5"/>
            <corners android:bottomRightRadius="4dp"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
