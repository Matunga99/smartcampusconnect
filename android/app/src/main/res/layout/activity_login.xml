<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0f172a"> <!-- Tailwind slate-900 background -->

    <!-- Elegant top card header -->
    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_dialog_map"
        app:tint="#4f46e5" /> <!-- Indigo primary dye -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_title"
        android:textColor="#ffffff"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consolidated Multi-Tenant Portal Access"
        android:textColor="#94a3b8"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:layout_bottom="24dp"
        android:layout_marginBottom="32dp"/>

    <!-- API server URL Configuration Input Field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColorHint="#64748b"
        app:boxStrokeColor="#4f46e5"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_api_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_url_hint"
            android:text="https://ais-dev-kgj4efa3zezeyu4wyibiv3-72418098555.europe-west2.run.app"
            android:textColor="#ffffff"
            android:inputType="textUri"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Email Identifier or RegNo Input Field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColorHint="#64748b"
        app:boxStrokeColor="#4f46e5"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_identity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/email_hint"
            android:textColor="#ffffff"
            android:inputType="textEmailAddress"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password Input Field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textColorHint="#64748b"
        app:boxStrokeColor="#4f46e5"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#64748b"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/password_hint"
            android:textColor="#ffffff"
            android:inputType="textPassword"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Button triggers Authenticator stream -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_login"
        android:textAllCaps="true"
        android:backgroundTint="#4f46e5"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:cornerRadius="12dp" />

    <!-- Error container -->
    <TextView
        android:id="@+id/tv_login_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ef4444"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:gravity="center" />

</LinearLayout>
