<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions required for Server Interoperability -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartCampusConnectX"
        android:usesCleartextTraffic="true">

        <!-- Gateway / Secure Login activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartCampusConnectX.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Role Directories Target Activity Screens -->
        <activity
            android:name=".SuperAdminActivity"
            android:exported="false"
            android:label="Super Admin Portal" />
            
        <activity
            android:name=".AdminActivity"
            android:exported="false"
            android:label="Admin Operations Council" />
            
        <activity
            android:name=".LecturerActivity"
            android:exported="false"
            android:label="Academic Staff Arena" />
            
        <activity
            android:name=".StudentActivity"
            android:exported="false"
            android:label="Student Digital Center" />
            
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Unified Profile Settings" />

    </application>

</manifest>
